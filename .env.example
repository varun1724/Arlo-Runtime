# Postgres
POSTGRES_USER=arlo
POSTGRES_PASSWORD=arlo_dev_password
POSTGRES_DB=arlo
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://arlo:arlo_dev_password@db:5432/arlo

# Auth
ARLO_AUTH_TOKEN=change-me-to-a-real-secret

# Workspace
WORKSPACE_ROOT=/workspaces

# Worker
WORKER_POLL_INTERVAL_SECONDS=2

# API
API_HOST=0.0.0.0
API_PORT=8000

# Claude Code CLI
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_COMMAND=claude
CLAUDE_MODEL=
RESEARCH_MODEL=sonnet
BUILDER_MODEL=opus
RESEARCH_TIMEOUT_SECONDS=1800
BUILDER_TIMEOUT_SECONDS=1200

# Trading engine
TRADING_ENGINE_URL=http://arlo-trading-engine-api-1:8000
TRADING_ENGINE_API_KEY=arlo-trading-dev-key
TRADING_TIMEOUT_SECONDS=3600

# n8n
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=arlo-n8n-dev-key

# Tailscale (informational — Tailscale is set up on the host, not in Docker)
TAILSCALE_HOSTNAME=arlo-runtime

# Round 5: email notifications (async approval flow)
# Leave APPROVAL_RECIPIENT_EMAIL blank to disable notifications entirely.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=arlo@localhost
APPROVAL_RECIPIENT_EMAIL=
# Public base URL the approval/download links should point to. For a
# Tailscale-only setup this is your Windows host's Tailscale IP, e.g.
# http://100.75.94.x:8000
NOTIFICATION_BASE_URL=http://localhost:8000
